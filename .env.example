# === Required ===

# Discord bot token (from Developer Portal > Bot > Token)
DISCORD_TOKEN=

# HTTPS clone URL for the target project repo
GIT_REPO_URL=https://github.com/you/your-project.git

# GitHub/GitLab personal access token (needs push access)
GIT_TOKEN=

# === Claude Auth (one of these) ===

# Option A: API key from console.anthropic.com
ANTHROPIC_API_KEY=

# Option B: Base64-encoded credentials from Claude Code's keychain
# Get it with: security find-generic-password -s "Claude Code-credentials" -w | base64
CLAUDE_CREDENTIALS=

# === Optional ===

# Branch to commit and push to
GIT_BRANCH=master

# Git identity for commits
GIT_USER_NAME=Vibez Bot
GIT_USER_EMAIL=vibez@bot

# Restrict bot to specific Discord channels (comma-separated IDs)
DISCORD_CHANNEL_IDS=

# Bot's own repo URL (optional — enables "fix bot" commands)
BOT_REPO_URL=

# Cost cap per request in USD
MAX_BUDGET_PER_REQUEST=5

# Max pending requests in queue
MAX_QUEUE_SIZE=10

# Timeout per Claude invocation in milliseconds (default: 10 min)
CLAUDE_TIMEOUT_MS=600000

# === Railway (optional — enables deploy checking + auto-fix) ===

# Railway API token (from railway.app > Account Settings > Tokens)
DEPLOY_RAILWAY_TOKEN=

# Target project's Railway service and environment IDs (from the project URL)
DEPLOY_RAILWAY_SERVICE=
DEPLOY_RAILWAY_ENVIRONMENT=

# Max auto-fix attempts when a deploy fails
MAX_FIX_ATTEMPTS=3
